@model RentACar.Models.Reservation

@{
    ViewData["Title"] = "Create Reservation";
}

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="card shadow-lg">

            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">📅 Reserve Car</h4>
            </div>

            <div class="card-body">

                <form asp-action="Create" method="post">

                    @Html.AntiForgeryToken()

                    <!-- ВАЖНО: CarId трябва да има стойност -->
                    <input asp-for="CarId" type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate"
                               type="date"
                               class="form-control"
                               id="StartDate" value="" />
                        <span asp-validation-for="StartDate"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate"
                               class="form-control"
                               type="date" value="" />
                        <span asp-validation-for="EndDate"
                              class="text-danger"></span>
                    </div>

                    <div class="alert alert-info">
                        Duration: <strong id="days">-</strong> days
                    </div>

                    <div class="d-flex justify-content-between">

                        <a asp-controller="Cars"
                           asp-action="All"
                           class="btn btn-secondary">
                            Cancel
                        </a>

                        <button type="submit"
                                class="btn btn-primary">
                            Reserve
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const startInput = document.getElementById("StartDate");
        const endInput = document.getElementById("EndDate");
        const daysEl = document.getElementById("days");

        function calculateDays() {
            const start = new Date(startInput.value);
            const end = new Date(endInput.value);

            if (start && end && end >= start) {
                const diffTime = end - start;
                const diffDays = diffTime / (1000 * 60 * 60 * 24) + 1;
                daysEl.textContent = diffDays;
            } else {
                daysEl.textContent = "-";
            }
        }

        startInput.addEventListener("change", calculateDays);
        endInput.addEventListener("change", calculateDays);
    </script>
}
@* section Scripts *@ 
    <script>

        const start = document.getElementById("StartDate");
        const end = document.getElementById("EndDate");
        const days = document.getElementById("days");

        function calculate() {

            if (!start.value || !end.value) {
                days.innerText = "-";
                return;
            }

            const s = new Date(start.value);
            const e = new Date(end.value);

            const diff = (e - s) / (1000 * 60 * 60 * 24);

            if (diff > 0) {
                days.innerText = diff + " day(s)";
            } else {
                days.innerText = "-";
            }
        }

        start.addEventListener("change", calculate);
        end.addEventListener("change", calculate);

    </script>