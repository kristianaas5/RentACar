@model IEnumerable<RentACar.Models.Reservation>

@*
    VIEW: My Reservations

    Summary:
    - Purpose: Displays the reservations belonging to the currently authenticated user.
    - Model: IEnumerable<RentACar.Models.Reservation>
    - UI: Card layout per reservation showing car (brand/model), start/end dates,
      description, seating capacity, total price and a status badge (Active / Cancelled).
    - Authorization & behavior: The controller action _ReservationController.My()_
      obtains the current user, loads their reservations (includes Car), and returns this view.
      The layout may hide the "My Reservations" link for Admin users; server-side checks remain in controller.
    - Notes:
      - Total price is computed as DailyPrice * number of days ((EndDate - StartDate).Days).
      - Dates are rendered with ToShortDateString(); adjust timezone logic if needed.
      - This file contains only presentation logic — validation and access control are handled by the controller.
*@

<h2 class="mb-4">📋 My Reservations</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You don't have any reservations yet.
    </div>
}

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card h-100 shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        🚗 @item.Car.Brand @item.Car.Model
                    </h5>

                    <p class="text-muted">
                        From:
                        <strong>
                            @item.StartDate.ToShortDateString()
                        </strong>
                    </p>

                    <p class="text-muted">
                        To:
                        <strong>
                            @item.EndDate.ToShortDateString()
                        </strong>
                    </p>
                    <p>
                        Description:
                            @item.Car.Description
                    </p>
                    <p class="text-muted">
                        Seats:
                        <strong>
                            @item.Car.SeatingCapacity
                        </strong>
                        <p class ="text-muted">
                        Total Price:
                        <strong>
                            $@(item.Car.DailyPrice * (item.EndDate - item.StartDate).Days)
                        </strong>
                    </p class="text-muted">

                    @* Status badge *@
                    @if (item.IsReserved)
                    {
                        <span class="badge bg-success">
                            Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            Cancelled
                        </span>
                    }

                </div>

            </div>

        </div>
    }

</div>