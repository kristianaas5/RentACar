
<div class="text-center py-5">

    <h1 class="display-4 fw-bold mb-3">
        Premium Car Rental Experience
    </h1>

    <p class="lead text-muted mb-4">
        Choose from our luxury and economy vehicles at the best prices
    </p>

    <a asp-controller="Cars"
       asp-action="All"
       class="btn btn-primary btn-lg">
        Browse Cars
    </a>

</div>

<div class="row mt-5">

    <div class="col-md-4">
        <div class="card p-4 text-center">
            <h4>🚗 Wide Selection</h4>
            <p class="text-muted">
                Economy, SUV, Luxury & Sports cars
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-4 text-center">
            <h4>💰 Best Prices</h4>
            <p class="text-muted">
                Competitive rental pricing
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-4 text-center">
            <h4>⚡ Fast Booking</h4>
            <p class="text-muted">
                Reserve your car in seconds
            </p>
        </div>
    </div>

</div>