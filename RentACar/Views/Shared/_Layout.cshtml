<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RentACar</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
      
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fb;
        }

        .navbar {
            background: linear-gradient(90deg,#0f172a,#1e293b);
        }

        .navbar-brand {
            font-weight: 600;
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
        }

        .nav-link:hover {
            color: #38bdf8 !important;
        }

        .main-container {
            min-height: 85vh;
        }

        .footer {
            background: #0f172a;
            color: white;
            padding: 20px;
            text-align: center;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            transition: 0.2s ease-in-out;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background: #2563eb;
            border: none;
            border-radius: 8px;
            padding: 8px 18px;
        }

        .btn-primary:hover {
            background: #1d4ed8;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark shadow">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                🚗 RentACar
            </a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">

                <ul class="navbar-nav me-auto">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="All">
                                Cars
                            </a>
                        </li>
                    }

                    @* Hide "My Reservations" for Admin users *@
                    @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservation" asp-action="My">
                                My Reservations
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservation" asp-action="All">
                                All Reservations
                            </a>
                            </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="Create">
                                Add Car
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="AllDelete">
                                Deleted Cars
                            </a>
                            </li>
                    }

                </ul>

                <ul class="navbar-nav">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link">
                                👤 @User.Identity.Name
                            </span>
                        </li>

                        <li class="nav-item">
                            <form  asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button class="nav-link" type="submit">Log out</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container main-container mt-4">
        @RenderBody()
    </div>

    <div class="footer">
        © 2026 RentACar | All Rights Reserved
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>