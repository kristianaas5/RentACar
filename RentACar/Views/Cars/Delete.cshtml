@model RentACar.Models.Car

@*
    VIEW: Delete Car
    Роля: Admin
    Описание:
    - Потвърждение преди soft delete
*@

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="card shadow-lg border-danger">

            <div class="card-header bg-danger text-white">
                <h4>⚠️ Delete Car</h4>
            </div>

            <div class="card-body">

                <h5>
                    Are you sure you want to delete this car?
                </h5>

                <hr />

                <p><strong>Brand:</strong> @Model.Brand</p>
                <p><strong>Model:</strong> @Model.Model</p>
                <p><strong>Year:</strong> @Model.Year</p>
                <p><strong>Price:</strong> $@Model.DailyPrice</p>

                <form asp-action="Delete" method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-between">

                        <a asp-action="All" class="btn btn-secondary">
                            Cancel
                        </a>

                        <button type="submit" class="btn btn-danger">
                            Delete
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>