@model RentACar.Models.Car

@*
    VIEW: Car Details
    Описание:
    - Показва информация за автомобил
*@

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card shadow">

            <div class="card-header bg-dark text-white">
                <h4>@Model.Brand @Model.Model</h4>
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6">
                        <p><strong>Year:</strong> @Model.Year</p>
                        <p><strong>Seats:</strong> @Model.SeatingCapacity</p>
                    </div>

                    <div class="col-md-6">
                        <p><strong>Price:</strong> $@Model.DailyPrice / day</p>
                    </div>

                </div>

                <hr />

                <p>@Model.Description</p>

                <div class="d-flex justify-content-between">

                    <a asp-action="All" class="btn btn-secondary">
                        Back
                    </a>

                    <a asp-controller="Reservation"
                       asp-action="Create"
                       asp-route-carId="@Model.Id"
                       class="btn btn-primary">
                        Reserve
                    </a>

                </div>

            </div>
        </div>

    </div>
</div>