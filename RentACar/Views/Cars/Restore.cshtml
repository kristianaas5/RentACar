@model RentACar.Models.Car

@{
    ViewData["Title"] = "Restore Car";
}

<h2>Restore Car</h2>

<h4>Are you sure you want to restore this car?</h4>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-2">Brand</dt>
        <dd class="col-sm-10">@Model.Brand</dd>

        <dt class="col-sm-2">Model</dt>
        <dd class="col-sm-10">@Model.Model</dd>

        <dt class="col-sm-2">Year</dt>
        <dd class="col-sm-10">@Model.Year</dd>

        <dt class="col-sm-2">Seats</dt>
        <dd class="col-sm-10">@Model.SeatingCapacity</dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.DailyPrice</dd>
    </dl>
</div>

<form asp-action="Restore" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-success">Restore</button>
    <a asp-action="AllDelete" class="btn btn-secondary">Cancel</a>
</form>