@model RentACar.Models.Reservation

@*
    VIEW: Create Reservation
    Описание:
    - Създаване на нова резервация
    - Показва календар за избор на дати
    - Изчислява продължителност (UI only)
*@

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="card shadow-lg">

            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">📅 Reserve Car</h4>
            </div>

            <div class="card-body">

                <form asp-action="Create" method="post">

                    @Html.AntiForgeryToken()

                    @* Hidden CarId *@
                    <input type="hidden" asp-for="CarId" />

                    @* Validation errors *@
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    @* Start Date *@
                    <div class="mb-3">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate"
                               type="date"
                               class="form-control"
                               id="StartDate" />
                        <span asp-validation-for="StartDate"
                              class="text-danger"></span>
                    </div>

                    @* End Date *@
                    <div class="mb-3">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate"
                               type="date"
                               class="form-control"
                               id="EndDate" />
                        <span asp-validation-for="EndDate"
                              class="text-danger"></span>
                    </div>

                    @* Duration info (UI only) *@
                    <div class="alert alert-info">
                        Duration: <strong id="days">-</strong>
                    </div>

                    <div class="d-flex justify-content-between">

                        <a asp-controller="Cars"
                           asp-action="All"
                           class="btn btn-secondary">
                            Cancel
                        </a>

                        <button type="submit"
                                class="btn btn-primary">
                            Reserve
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>

        const start = document.getElementById("StartDate");
        const end = document.getElementById("EndDate");
        const days = document.getElementById("days");

        function calculate() {

            if (!start.value || !end.value) {
                days.innerText = "-";
                return;
            }

            const s = new Date(start.value);
            const e = new Date(end.value);

            const diff = (e - s) / (1000 * 60 * 60 * 24);

            if (diff > 0) {
                days.innerText = diff + " day(s)";
            } else {
                days.innerText = "-";
            }
        }

        start.addEventListener("change", calculate);
        end.addEventListener("change", calculate);

    </script>
}